# Copie para .env.local e preencha. Nunca commitar .env.local.

# Identidade de assinatura. Use "-" para ad-hoc (local dev sem notarização).
# Para distribuição via Gatekeeper: "Developer ID Application: Nome (TEAMID)"
KRIT_CODESIGN_IDENTITY=

# Nome do perfil armazenado no Keychain pelo comando:
#   xcrun notarytool store-credentials "KritNotaryProfile"
# Apenas necessário para notarização (requer Developer ID, não funciona com ad-hoc).
KRIT_NOTARY_PROFILE=KritNotaryProfile

# Caminho opcional do .app já compilado. Padrão: /Applications/KRIT.app
# Útil quando o bundle foi compilado em outro local antes de rodar make-dmg.sh.
# KRIT_APP_PATH=/Applications/KRIT.app
